# Copy to .env and adjust
DATABASE_URL=postgresql+psycopg2://cgd:cgd_dev_change_me@127.0.0.1:5432/cgd
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

SEMANTICS_VERSION=1
MATRIX_VERSION=1
# 1 = gaps stay DETECTED only (no Telegram). 0 = allow ESCALATED → dispatch_alerts → Telegram.
SHADOW_MODE=1

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Comma-separated RPC URLs per chain key: ethereum=https://...,https://fallback...
RPC_URLS_ETHEREUM=
